{
  "name": "swg-ui-editor-swglayoutengine",
  "version": "1.0.0",
  "description": "Desktop wrapper for the SWG Galaxy Map UI editor",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:dir": "electron-builder --win --dir"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.swg.uieditor",
    "productName": "SWG UI Editor",
    "files": [
      "main.js",
      "SWG-UI-Editor/**/*",
      "ui/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    }
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1"
  }
}
